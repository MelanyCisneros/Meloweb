---
import { Image } from "astro:assets";
import bassPortrait from "../../assets/images/Melobass-bass-portrait.jpg";
---
<section id="bass" data-screen-label="05 Bass">
  <div class="container">
    <h2 class="bass-wordmark">Melo<span class="accent">bass</span></h2>

    <div class="bass-grid">
      <div class="bass-portrait">
        <Image
          src={bassPortrait}
          alt="Melo with bass"
          widths={[480, 768, 1024, 1280]}
          sizes="(max-width: 820px) 100vw, 40vw"
          quality={80}
          format="webp"
          loading="lazy"
        />
      </div>

      <div>
        <div class="playlist-head">
          <span class="playlist-meta" data-en>Public Playlist</span>
          <span class="playlist-meta" data-es>Lista Pública</span>
          <span class="playlist-bar"></span>
        </div>
        <div class="playlist-embed">
          <iframe
            src="https://open.spotify.com/embed/playlist/01ybhAlGVRe1VPlZmTMdHC?utm_source=generator&theme=0"
            title="Melobasslines playlist on Spotify"
            loading="lazy"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            allowfullscreen
            frameborder="0"
          ></iframe>
        </div>

        <div class="live-head">
          <span data-en>Live / Studio Performance</span>
          <span data-es>En vivo / En estudio</span>
          <span class="bar"></span>
        </div>
        <div class="live-videos">
          <div class="player-media embed" data-provider="youtube">
            <iframe
              src="https://www.youtube-nocookie.com/embed/fqcUQ73zdZM?rel=0&modestbranding=1"
              title="Live 01"
              loading="lazy"
              allowfullscreen
              allow="autoplay; encrypted-media"
              frameborder="0"
              style="width:100%;height:100%;border:0;background:#000"
            ></iframe>
          </div>
          <div class="player-media embed" data-provider="youtube">
            <iframe
              src="https://www.youtube-nocookie.com/embed/VIOf6GmIr8U?rel=0&modestbranding=1"
              title="Live 02"
              loading="lazy"
              allowfullscreen
              allow="autoplay; encrypted-media"
              frameborder="0"
              style="width:100%;height:100%;border:0;background:#000"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
